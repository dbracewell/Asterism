# BetterAuth runtime secret (generate a strong random value)
BETTER_AUTH_SECRET=replace-with-random-secret

# Frontend public URL for BetterAuth callbacks
BETTER_AUTH_URL=http://localhost:3000

# Path to BetterAuth SQLite database file
BETTER_AUTH_DB_PATH=/absolute/path/to/storage/users.db

# Backend API base URL used by the frontend client
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:8000
