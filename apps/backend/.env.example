# Backend storage root for SQLite DB and uploaded files
# Defaults to /storage if not set
STORAGE_ROOT=/absolute/path/to/storage

# Optional frontend URL used by default Better Auth JWT checks
# FRONT_END_URL=http://localhost:3000

# Optional Better Auth/JWT overrides (useful when backend/frontend have different public URLs)
# BETTER_AUTH_URL=http://localhost:3000
# JWKS_URL=http://localhost:3000/api/auth/jwks
# JWT_ISSUER=http://localhost:3000
# JWT_AUDIENCE=http://localhost:3000

# Optional DB override values (defaults are suitable for local SQLite)
# DB_CONNECTION=sqlite+aiosqlite
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=change-me
# DB_SCHEMA=asterism
